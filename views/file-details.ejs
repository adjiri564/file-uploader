<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>File Details - File Uploader</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        .file-details-card {
            background: white;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }
        .file-icon-large {
            font-size: 4rem;
            color: #667eea;
        }
        .file-info-item {
            padding: 1rem;
            border-bottom: 1px solid #dee2e6;
        }
        .file-info-item:last-child {
            border-bottom: none;
        }
        .download-btn {
            background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
            border: none;
            padding: 12px 30px;
            font-size: 1.1rem;
        }
        .download-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }
        .back-btn {
            background: linear-gradient(135deg, #6c757d 0%, #495057 100%);
            border: none;
            padding: 10px 20px;
        }
        .back-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }
    </style>
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="file-details-card">
                    <div class="card-header bg-primary text-white text-center py-4">
                        <i class="fas fa-file file-icon-large mb-3"></i>
                        <h2 class="mb-0"><%= file.originalName %></h2>
                    </div>
                    
                    <div class="card-body p-0">
                        <div class="file-info-item">
                            <div class="row">
                                <div class="col-md-6">
                                    <strong>File Name:</strong>
                                </div>
                                <div class="col-md-6">
                                    <%= file.originalName %>
                                </div>
                            </div>
                        </div>
                        
                        <div class="file-info-item">
                            <div class="row">
                                <div class="col-md-6">
                                    <strong>File Size:</strong>
                                </div>
                                <div class="col-md-6">
                                    <%= (file.fileSize / 1024 / 1024).toFixed(2) %> MB
                                </div>
                            </div>
                        </div>
                        
                        <div class="file-info-item">
                            <div class="row">
                                <div class="col-md-6">
                                    <strong>File Type:</strong>
                                </div>
                                <div class="col-md-6">
                                    <%= file.mimeType %>
                                </div>
                            </div>
                        </div>
                        
                        <div class="file-info-item">
                            <div class="row">
                                <div class="col-md-6">
                                    <strong>Upload Date:</strong>
                                </div>
                                <div class="col-md-6">
                                    <%= new Date(file.createdAt).toLocaleString() %>
                                </div>
                            </div>
                        </div>
                        
                        <div class="file-info-item">
                            <div class="row">
                                <div class="col-md-6">
                                    <strong>Last Modified:</strong>
                                </div>
                                <div class="col-md-6">
                                    <%= new Date(file.updatedAt).toLocaleString() %>
                                </div>
                            </div>
                        </div>
                        
                        <% if (file.folderId) { %>
                        <div class="file-info-item">
                            <div class="row">
                                <div class="col-md-6">
                                    <strong>Location:</strong>
                                </div>
                                <div class="col-md-6">
                                    <i class="fas fa-folder text-warning me-2"></i>
                                    <span>In Folder</span>
                                </div>
                            </div>
                        </div>
                        <% } %>
                    </div>
                    
                    <div class="card-footer text-center py-4">
                        <div class="row">
                            <div class="col-md-6">
                                <a href="/dashboard" class="btn back-btn text-white w-100">
                                    <i class="fas fa-arrow-left me-2"></i>Back to Dashboard
                                </a>
                            </div>
                            <div class="col-md-6">
                                <a href="/files/download/<%= file.id %>" class="btn download-btn text-white w-100">
                                    <i class="fas fa-download me-2"></i>Download File
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- File Preview Section -->
                <div class="card mt-4">
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="fas fa-eye me-2"></i>File Preview
                        </h5>
                    </div>
                    <div class="card-body text-center">
                        <% if (file.mimeType.startsWith('image/')) { %>
                            <img src="<%= file.fileUrl %>" alt="<%= file.originalName %>" class="img-fluid" style="max-height: 400px;">
                        <% } else if (file.mimeType.startsWith('text/')) { %>
                            <div class="text-start">
                                <pre class="bg-light p-3 rounded"><code id="fileContent">Loading...</code></pre>
                            </div>
                        <% } else if (file.mimeType.startsWith('video/')) { %>
                            <video controls class="w-100" style="max-height: 400px;">
                                <source src="<%= file.fileUrl %>" type="<%= file.mimeType %>">
                                Your browser does not support the video tag.
                            </video>
                        <% } else if (file.mimeType.startsWith('audio/')) { %>
                            <audio controls class="w-100">
                                <source src="<%= file.fileUrl %>" type="<%= file.mimeType %>">
                                Your browser does not support the audio tag.
                            </audio>
                        <% } else { %>
                            <div class="text-center py-5">
                                <i class="fas fa-file fa-4x text-muted mb-3"></i>
                                <p class="text-muted">Preview not available for this file type</p>
                                <a href="/files/download/<%= file.id %>" class="btn btn-primary">
                                    <i class="fas fa-download me-2"></i>Download to View
                                </a>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Load text file content for preview
        <% if (file.mimeType.startsWith('text/')) { %>
        fetch('<%= file.fileUrl %>')
            .then(response => response.text())
            .then(content => {
                document.getElementById('fileContent').textContent = content;
            })
            .catch(error => {
                document.getElementById('fileContent').textContent = 'Error loading file content';
                console.error('Error:', error);
            });
        <% } %>
    </script>
</body>
</html>


