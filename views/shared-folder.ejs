<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shared Folder - File Uploader</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        body { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 100vh; }
        .shared-folder-card { background: white; border-radius: 15px; box-shadow: 0 15px 35px rgba(0,0,0,0.1); margin-top: 2rem; }
        .shared-header { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 2rem; text-align: center; border-radius: 15px 15px 0 0; }
        .folder-item, .file-item { border: 1px solid #dee2e6; border-radius: 10px; padding: 1rem; margin-bottom: 1rem; transition: all 0.3s ease; }
        .folder-item:hover, .file-item:hover { transform: translateY(-2px); box-shadow: 0 4px 8px rgba(0,0,0,0.1); }
        .expiry-info { background: #fff3cd; border: 1px solid #ffeaa7; border-radius: 10px; padding: 1rem; margin-bottom: 1rem; }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="shared-folder-card">
                    <div class="shared-header">
                        <i class="fas fa-share-alt fa-3x mb-3"></i>
                        <h2>Shared Folder</h2>
                        <p class="mb-0"><%= sharedFolder.folder.name %></p>
                        <% if (sharedFolder.folder.description) { %>
                            <p class="mb-0 mt-2"><%= sharedFolder.folder.description %></p>
                        <% } %>
                    </div>
                    
                    <div class="card-body p-4">
                        <div class="expiry-info">
                            <i class="fas fa-clock text-warning me-2"></i>
                            <strong>This shared link expires on:</strong>
                            <span class="ms-2"><%= new Date(sharedFolder.expiresAt).toLocaleString() %></span>
                        </div>

                        <h5><i class="fas fa-folder text-warning me-2"></i>Folders</h5>
                        <% if (sharedFolder.folder.children && sharedFolder.folder.children.length > 0) { %>
                            <div class="row">
                                <% sharedFolder.folder.children.forEach(function(childFolder) { %>
                                    <div class="col-md-6 col-lg-4">
                                        <div class="folder-item">
                                            <i class="fas fa-folder text-warning fa-2x me-3"></i>
                                            <h6><%= childFolder.name %></h6>
                                            <% if (childFolder.description) { %>
                                                <small class="text-muted"><%= childFolder.description %></small>
                                            <% } %>
                                        </div>
                                    </div>
                                <% }); %>
                            </div>
                        <% } else { %>
                            <p class="text-muted">No subfolders found.</p>
                        <% } %>

                        <h5 class="mt-4"><i class="fas fa-file text-primary me-2"></i>Files</h5>
                        <% if (sharedFolder.folder.files && sharedFolder.folder.files.length > 0) { %>
                            <div class="row">
                                <% sharedFolder.folder.files.forEach(function(file) { %>
                                    <div class="col-md-6 col-lg-4">
                                        <div class="file-item">
                                            <i class="fas fa-file text-primary fa-2x me-3"></i>
                                            <h6><%= file.originalName %></h6>
                                            <small class="text-muted">
                                                <%= (file.fileSize / 1024 / 1024).toFixed(2) %> MB
                                            </small>
                                        </div>
                                    </div>
                                <% }); %>
                            </div>
                        <% } else { %>
                            <p class="text-muted">No files found.</p>
                        <% } %>

                        <div class="text-center mt-5 pt-4 border-top">
                            <p class="text-muted">This is a shared folder from File Uploader.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
